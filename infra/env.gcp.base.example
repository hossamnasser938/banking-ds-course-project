# Shared values for all regions.
# Copy to: infra/env.gcp.base

export PROJECT_ID="<YOUR_GCP_PROJECT_ID>"

# Shared DB settings
export DB_PORT="5432"
export DB_USER="postgres"
export DB_PASSWORD="<YOUR_DB_PASSWORD>"
export DB_NAME="banking"

# Optional Cloud SQL socket mode (if used, DB_HOST from region file can be omitted)
# export DB_SOCKET_PATH="/cloudsql/<PROJECT:REGION:INSTANCE>"

# Optional DB transport settings
export DB_SSL="false"
export DB_SSL_REJECT_UNAUTHORIZED="true"

export AUTH_INTERNAL_API_KEY="<YOUR_SHARED_INTERNAL_KEY>"

# Optional
export TAG="latest"
export CORS_ORIGIN=""
export SERVICE_PREFIX="banking"
